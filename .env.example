# API keys
OPENAI_API_KEY=
OTX_API_KEY=
PINECONE_API_KEY=

# RAG
PINECONE_INDEX_NAME=cyber-llm-knowledge
ENABLE_RAG=true
RAG_MAX_RESULTS=3

# Models
FAST_MODEL_NAME=gpt-4o-mini
STRONG_MODEL_NAME=gpt-4o
TEMPERATURE=0.3
MAX_TOKENS=2000

# Memory recall embeddings (OpenAI)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Agent execution controls (G1/G2)
MAX_AGENT_STEPS=12
MAX_TOOL_CALLS=8
MAX_RUNTIME_SECONDS=60
MAX_WORKER_TASKS=4

# Prompting and safety (G1/G2)
PROMPT_VERSION_G1=security_analysis_v2.txt
PROMPT_VERSION_G2=security_analysis_v2.txt
REQUIRE_HUMAN_APPROVAL_HIGH_RISK=false

# Data paths
DATA_DIR=./data
LOGS_DIR=./data/logs
SESSIONS_DIR=./data/sessions
KNOWLEDGE_DIR=./data/knowledge