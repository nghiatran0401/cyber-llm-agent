# API keys
OPENAI_API_KEY=
OTX_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=cyber-llm-knowledge

# RAG — Pinecone + OpenAI embeddings over data/knowledge (ingest on demand; see README)
ENABLE_RAG=true
RAG_MAX_RESULTS=3

# Models
FAST_MODEL_NAME=gpt-4o-mini
STRONG_MODEL_NAME=gpt-4o
TEMPERATURE=0.3
MAX_TOKENS=2000

# Memory recall embeddings (OpenAI; uses OPENAI_API_KEY above)
EMBEDDING_ENABLED=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Agent execution controls
MAX_AGENT_STEPS=12
MAX_TOOL_CALLS=8
MAX_RUNTIME_SECONDS=60
MAX_WORKER_TASKS=4

# Prompting and safety
PROMPT_VERSION_G1=security_analysis_v2.txt
PROMPT_VERSION_G2=security_analysis_v2.txt
ENABLE_RUBRIC_EVAL=true
ENABLE_OUTPUT_POLICY_GUARD=true
REQUIRE_HUMAN_APPROVAL_HIGH_RISK=false
MIN_EVIDENCE_FOR_HIGH_RISK=1

# Data paths
DATA_DIR=./data
LOGS_DIR=./data/logs
SESSIONS_DIR=./data/sessions
KNOWLEDGE_DIR=./data/knowledge

# OWASP lab (apps/vuln-lab) — Node only; not read by Python Settings
LAB_MODE=vulnerable
LAB_HOST=127.0.0.1
LAB_PORT=3100
CTI_API_BASE=http://127.0.0.1:8000
CTI_BRIDGE_MODE=both
CTI_ANALYZE_MODE=g1
CTI_BATCH_SIZE=8
CTI_FLUSH_MS=7000

# Next.js — copy to apps/web/.env.local for `make run-web`; Compose reads these as build args from root .env
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_LAB_BASE_URL=http://127.0.0.1:3100