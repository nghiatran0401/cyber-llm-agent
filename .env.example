# Required secrets (see src/config/settings.py — validation runs on API startup unless PYTEST_CURRENT_TEST is set)
OPENAI_API_KEY=your-openai-api-key
OTX_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=cyber-llm-knowledge

# RAG (Pinecone). API startup validation still requires PINECONE_* even when ENABLE_RAG=false.
ENABLE_RAG=true
CTI_PROVIDER=otx

# Runtime: development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Models — G1 always routes high-risk requests to STRONG_MODEL_NAME (no env toggle)
FAST_MODEL_NAME=gpt-4o-mini
STRONG_MODEL_NAME=gpt-4o
TEMPERATURE=0.3
MAX_TOKENS=2000

ENABLE_SANDBOX=false

API_AUTH_ENABLED=false
API_AUTH_KEY=
API_RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=60
VALIDATE_ON_STARTUP=true
AGENT_CACHE_TTL_SECONDS=3600
AGENT_CACHE_MAX_SIZE=100
MAX_AGENT_STEPS=12
MAX_TOOL_CALLS=8
MAX_RUNTIME_SECONDS=60
MAX_WORKER_TASKS=4
MEMORY_MAX_EPISODIC_ITEMS=30
MEMORY_MAX_SEMANTIC_FACTS=80
MEMORY_RECALL_TOP_K=3
SESSION_RETENTION_DAYS=30
PROMPT_VERSION_G1=security_analysis_v2.txt
PROMPT_VERSION_G2=security_analysis_v2.txt
ENABLE_RUBRIC_EVAL=true
ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_OUTPUT_POLICY_GUARD=true
REQUIRE_HUMAN_APPROVAL_HIGH_RISK=false
MIN_EVIDENCE_FOR_HIGH_RISK=1

OTX_BASE_URL=https://otx.alienvault.com/api/v1
CTI_REQUEST_TIMEOUT_SECONDS=10
CTI_MAX_RETRIES=2
CTI_RETRY_BACKOFF_SECONDS=0.5
CTI_MAX_RESPONSE_CHARS=3000
CTI_TOP_RESULTS=5

# Optional local path overrides
# DATA_DIR=./data
# LOGS_DIR=./data/logs
# SESSIONS_DIR=./data/sessions
# KNOWLEDGE_DIR=./data/knowledge

# OWASP vulnerable lab (apps/vuln-lab) — Node only; not read by Python Settings
# When running the lab on the host with `make run-lab`, point at the API on localhost.
# Docker Compose sets CTI_API_BASE=http://api:8000 inside the lab container (do not override for Compose).
LAB_MODE=vulnerable
LAB_HOST=127.0.0.1
LAB_PORT=3100
CTI_API_BASE=http://127.0.0.1:8000
CTI_BRIDGE_MODE=both
CTI_ANALYZE_MODE=g1
CTI_BATCH_SIZE=8
CTI_FLUSH_MS=7000

# Next.js (apps/web) — copy to apps/web/.env.local for local dev; Docker Compose also reads these from the repo root .env for build args
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_LAB_BASE_URL=http://127.0.0.1:3100
# NEXT_PUBLIC_API_KEY=
